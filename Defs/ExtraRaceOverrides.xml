<Defs>
  <HediffDef ParentName="BS_DefaultHumanlikeAnimal" MayRequire="sarg.alphaanimals">
    <defName>HL_AA_Animalisk_RaceHediff</defName> 
    <description>Thought to be psychically deaf to endure its diet of anima trees, but later studies instead revealed an unique ability to dispel neural interference.\n\nAnimalisks are most known from a highly successful series of plush toys and tv series.</description>
    <label>animalisk</label>
    <defaultLabelColor>(0.5, 1, 1)</defaultLabelColor>
    <stages>
      <li>
        <painFactor>1.2</painFactor>
        <statOffsets>
        </statOffsets>
        <statFactors>
          <PsychicSensitivity>0.5</PsychicSensitivity>
          <PsychicEntropyRecoveryRate>5</PsychicEntropyRecoveryRate>
          <PsychicEntropyMax>2</PsychicEntropyMax>
          <MeditationFocusGain>3</MeditationFocusGain>
        </statFactors>
      </li>
    </stages>
    <abilities>
      <li>AA_Web</li>
    </abilities>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
        <traitIcon>Things/Pawn/Animal/AA_Animalisk/AA_Animalisk_east</traitIcon>
        <animalFineManipulation>1.0</animalFineManipulation>
        <aptitudes>
          <Crafting>2</Crafting>
        </aptitudes>
        <nullsThoughts>
          <li>AnimaScream</li>
          <li>PsychicDrone</li>
        </nullsThoughts>
      </li>
    </modExtensions>
  </HediffDef>

  <HediffDef ParentName="BS_DefaultHumanlikeAnimal" MayRequire="VanillaExpanded.VAEWaste">
    <defName>HL_VAEWaste_Hydra_RaceHediff</defName> 
    <description>The Hydra is a fearsome creature, mutated by the toxic environment to become a three-headed snake.\n\nLiving primarily in water, two of its heads remain submerged while only one absorbs oxygen.\n\nIt is quick, vicious, and capable of wearing 3 top hats.</description>
    <label>hydra</label>
    <defaultLabelColor>(0.5, 1, 1)</defaultLabelColor>
    <stages>
      <li>
        <statOffsets>
          <MeleeDodgeChance>5</MeleeDodgeChance>
          <MedicalTendQualityOffset>0.20</MedicalTendQualityOffset>
        </statOffsets>
        <statFactors>
          <IncomingDamageFactor>0.8</IncomingDamageFactor>
          <ImmunityGainSpeedFactor>1.3</ImmunityGainSpeedFactor>
        </statFactors>
      </li>
    </stages>
    <modExtensions>
      <li Class="BigAndSmall.PawnExtension">
        <traitIcon>Things/Pawn/Animal/AA_Animalisk/AA_Animalisk_east</traitIcon>
        <animalFineManipulation>1.0</animalFineManipulation>
        <aptitudes>
          <Medicine>2</Medicine>
        </aptitudes>
      </li>
    </modExtensions>
  </HediffDef>



</Defs>